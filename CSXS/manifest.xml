<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest
    Version="6.0"
    ExtensionBundleId="com.compmaker"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="CompMaker"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.compmaker.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- After Effects, all versions -->
            <Host Name="AEFT" Version="[0.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.compmaker.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <!-- Enable Node.js APIs (fs, path) and a single shared JS context -->
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>CompMaker</Menu>
                    <Geometry>
                        <Size>
                            <Height>560</Height>
                            <Width>360</Width>
                        </Size>
                        <MinSize>
                            <Height>320</Height>
                            <Width>280</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2400</Height>
                            <Width>1200</Width>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
